FROM eclipse-temurin:21-jre-alpine

# Create non-root user (UID/GID 1000) - recommended for security
RUN addgroup -g 1000 appgroup && \
    adduser -D -u 1000 -G appgroup appuser

# Create directories
RUN mkdir -p /app /data /data-init && \
    chown -R appuser:appgroup /app /data /data-init

# Install rclone (static binary) + certificates
RUN apk add --no-cache ca-certificates curl tar zip && \
    apk add --no-cache --virtual .build-deps unzip && \
    curl -L --silent -o /tmp/rclone.zip https://downloads.rclone.org/rclone-current-linux-amd64.zip && \
    unzip /tmp/rclone.zip -d /tmp && \
    mv /tmp/rclone-*/rclone /usr/local/bin/rclone && \
    chmod +x /usr/local/bin/rclone && \
    rm -rf /tmp/* && \
    apk del .build-deps

# Copy and prepare backup.sh
COPY --chown=appuser:appgroup --chmod=0744 src/main/container/backup.sh /app/

# Populate immutable default data (copied into /data on first boot)
COPY --chown=appuser:appgroup --chmod=0744 src/main/container/entrypoint.sh /app/
COPY --chown=appuser:appgroup --chmod=0644 src/main/container/application-default.properties /data-init/
COPY --chown=appuser:appgroup --chmod=0644 src/main/container/logback.xml /data-init/
COPY --chown=appuser:appgroup --chmod=0644 hsqldb/*.tar.gz /data-init/hsqldb.tar.gz

# Populate app
COPY --chown=appuser:appgroup --chmod=0644 target/*-boot.jar /app/app.jar

WORKDIR /data
USER appuser
EXPOSE 8080

# Declare /data as the mount point to bind with a Kubernetes PVC.
VOLUME ["/data"]

# Default command = run the Spring Boot app
# In Kubernetes Deployment/StatefulSet this stays as-is.
# In CronJob override with: command: ["/app/backup.sh"]
ENTRYPOINT ["/app/entrypoint.sh"]
