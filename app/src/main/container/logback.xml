<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} traceId=%X{trace_id} spanId=%X{span_id} - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- Optional: structured JSON for easier Loki parsing -->
    <!--
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <includeMdcKeyName>trace_id</includeMdcKeyName>
        <includeMdcKeyName>span_id</includeMdcKeyName>
      </encoder>
    </appender>
    -->

    <!-- OpenTelemetry javaagent logging -->
    <logger name="io.opentelemetry" level="INFO"/>
    <logger name="io.opentelemetry.javaagent" level="INFO"/>
    <logger name="io.opentelemetry.exporter" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>